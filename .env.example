# Tujuan
# Contoh environment variable minimum untuk menjalankan app.
# Caller
# Operator/developer lokal.
# Dependensi
# config.py.
# Main Functions
# Menjadi template .env.
# Side Effects
# Tidak ada.

# Telegram
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+6281234567890
TELEGRAM_GROUPS=-1002647537685,-1003629502181

# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Database
# Dipakai docker-compose untuk service postgres
POSTGRES_PASSWORD=your_secure_password
# Opsional untuk run langsung tanpa docker-compose
DATABASE_URL=postgresql+asyncpg://trader:your_secure_password@localhost:5432/caracrypto

# WuzAPI
WUZAPI_TOKEN=abc
WUZAPI_PHONE=120363426398056602@g.us

# Risk Management
TRADE_MARGIN_PERCENT=1
MAX_CONCURRENT_POSITIONS=5
MAX_POSITION_SIZE_PERCENT=10
DAILY_LOSS_LIMIT_PERCENT=5
HIGH_RISK_MULTIPLIER=0.5
